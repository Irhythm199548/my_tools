# my-tools 环境变量模板（配置中心注入示例）
# 复制本文件为 .env 并填入真实值；请勿把 .env 提交到代码仓库。
# 启动方式（二选一）：
#   Linux/Mac : export $(cat .env | xargs) && java -jar target/my-tools.jar
#   Windows   : 在启动脚本里 set MAIL_PASSWORD=xxx 后启动
#   或 JVM    : java -DMAIL_PASSWORD=xxx -jar target/my-tools.jar
#
# 容器/K8s/Spring Cloud Config/Nacos/Apollo 等配置中心：
#   直接以同名环境变量下发即可，应用无需改动。

# ===== 邮件 SMTP（必填，真实发信需要）=====
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=service_anchor@163.com
MAIL_PASSWORD=在此填入邮箱授权码
# From 必须与 MAIL_USERNAME 一致（163/QQ 强制），留空则自动等于 MAIL_USERNAME
MAIL_FROM=service_anchor@163.com

# ===== 默认管理员密码（可选，留空则随机生成并打印日志）=====
ADMIN_PASSWORD=851570973+

# ===== 配置中心 Nacos 地址（可选）=====
# 生产用 Nacos 时填这里（或在 Nacos 控制台建 my-tools.yaml 配置）。
# 留空默认 127.0.0.1:8848；本地没起 Nacos 也不影响启动（自动跳过）。
NACOS_SERVER_ADDR=127.0.0.1:8848
